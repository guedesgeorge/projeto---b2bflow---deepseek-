# ---- Supabase ----
# Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sua_chave_anon_public_aqui
# (opcional) nome da tabela, padrão = contatos
SUPABASE_TABELA=contatos

# ---- Z-API ----
# Painel da Z-API > Instâncias
ZAPI_INSTANCE_ID=sua_instance_id_aqui
ZAPI_INSTANCE_TOKEN=seu_instance_token_aqui
# Painel da Z-API > Segurança > Token de Segurança da Conta
ZAPI_CLIENT_TOKEN=seu_client_token_aqui

# (opcional) máximo de contatos a disparar, padrão = 3
LIMITE_CONTATOS=3
